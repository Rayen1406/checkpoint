HOST=0.0.0.0
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/hackathon_checkpoint
# Comma-separated list, example:
# CLIENT_ORIGIN=http://localhost:5173,https://your-public-domain.com
# Leave empty to allow all origins.
CLIENT_ORIGIN=http://localhost:5173
ADMIN_USERNAME=rayen
ADMIN_PASSWORD=rayen
JWT_SECRET=super-secret-change-me
# ISO format example: 2026-04-17T08:00:00.000Z
CHECKPOINT_BASE_TIME=2026-04-17T08:00:00.000Z
CHECKPOINT_INTERVAL_MINUTES=120
CHECKPOINT_WINDOW_MINUTES=15

# Telegram bot URL notifications on startup
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tunnel settings for notifier script
PUBLIC_PORT=4000
# Optional fixed localtunnel subdomain (may fail if already taken)
PUBLIC_SUBDOMAIN=
